   RowBox[{"{", 
    RowBox[{
     RowBox[{"0.5", "-", 
      RowBox[{"0.68", "/", "2"}]}], ",", 
     RowBox[{"0.5", "+", 
      RowBox[{"0.68", "/", "2"}]}]}], "}"}]}], ";"}]}], "Input",
