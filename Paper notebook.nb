Cell[CellGroupData[{

Cell["Density plots for varying the initial conditions", "Subsubsection",
 CellChangeTimes->{{3.9809316357325096`*^9, 
  3.9809316511627026`*^9}},ExpressionUUID->"14c20e82-1f90-1542-8bda-\
4f67e740db08"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"U", "=", 
   RowBox[{"UHadWalk", "[", "p", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Theta]", "=", 
   RowBox[{"0.01", "Pi"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[Phi]", "=", 
   RowBox[{"0.01", "Pi"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]Vals", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", "Pi", ",", "d\[Theta]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Phi]Vals", "=", 
    RowBox[{"Range", "[", 
     RowBox[{"0", ",", 
      RowBox[{"2", "Pi"}], ",", "d\[Phi]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"valsN2", "=", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"state", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], 
           RowBox[{"initState", "[", 
            RowBox[{"p", ",", "0", ",", "0"}], "]"}]}], "+", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "\[Phi]"}], "]"}], 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], " ", 
           RowBox[{"initState", "[", 
            RowBox[{"p", ",", "1", ",", "0"}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"1", "-", 
        RowBox[{"sepValOnePhoton", "[", 
         RowBox[{"evolveState", "[", 
          RowBox[{"U", ",", "state", ",", "2"}], "]"}], "]"}]}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "\[Theta]Vals"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Phi]", ",", "\[Phi]Vals"}], "}"}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "//", "AbsoluteTiming"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"valsN5", "=", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"state", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], 
           RowBox[{"initState", "[", 
            RowBox[{"p", ",", "0", ",", "0"}], "]"}]}], "+", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "\[Phi]"}], "]"}], 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], " ", 
           RowBox[{"initState", "[", 
            RowBox[{"p", ",", "1", ",", "0"}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"1", "-", 
        RowBox[{"sepValOnePhoton", "[", 
         RowBox[{"evolveState", "[", 
          RowBox[{"U", ",", "state", ",", "4"}], "]"}], "]"}]}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "\[Theta]Vals"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Phi]", ",", "\[Phi]Vals"}], "}"}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "//", "AbsoluteTiming"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"valsCoinEnt", "=", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Phi]1Asymp", "=", 
         RowBox[{
          RowBox[{"1", "/", "2"}], "-", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Sqrt", "[", "2", "]"}], "-", "1"}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", 
              RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}]}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Cos", "[", "\[Theta]", "]"}], "+", 
             RowBox[{
              RowBox[{"Sin", "[", "\[Theta]", "]"}], 
              RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], ")"}]}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Min", "[", 
         RowBox[{"\[Phi]1Asymp", ",", 
          RowBox[{"1", "-", "\[Phi]1Asymp"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "\[Theta]Vals"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Phi]", ",", "\[Phi]Vals"}], "}"}]}], "\[IndentingNewLine]",
       "]"}]}], ";"}], "//", "AbsoluteTiming"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ListDensityPlot", "[", "valsN2", "]"}], "\[IndentingNewLine]", 
 RowBox[{"ListDensityPlot", "[", "valsN5", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListDensityPlot", "[", "valsCoinEnt", "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<HW-ICs-Thetas.csv\>\"", ",", "\[Theta]Vals"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<HW-ICs-Phis.csv\>\"", ",", "\[Phi]Vals"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<HW-ICs-N=1-P=5-n=2.csv\>\"", ",", "valsN2"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<HW-ICs-N=1-P=5-n=4.csv\>\"", ",", "valsN5"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<HW-ICs-Coin_Ent-Asymptotic.csv\>\"", ",", "valsCoinEnt"}], 
  "]"}]}], "Input",
