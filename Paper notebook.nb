Cell[CellGroupData[{

Cell["\<\
Multiple walkers and genuine multipartite entanglement (Sec. IV.C)\
\>", "Subsection",
 CellChangeTimes->{{3.9809323546030617`*^9, 
  3.9809323841872063`*^9}},ExpressionUUID->"1e98b42e-e79b-db45-944d-\
8e5138ee804c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"maxSepValRandomNetwork", "[", "\[Psi]in_", "]"}], ":=", 
   RowBox[{"genuineMultiPartiteEntanglement", "[", 
    RowBox[{"sepValsAllBipartitions", "[", 
     RowBox[{"applyNetwork", "[", 
      RowBox[{"\[Psi]in", ",", 
       RowBox[{"randomUnitary", "@", 
        RowBox[{"getM", "@", "\[Psi]in"}]}]}], "]"}], "]"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"howMany", "=", "6000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"quantile", "=", "0.68"}], ";"}]}], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"6e6fb674-6f82-0442-9745-247cb5381e25"],

Cell[CellGroupData[{

Cell["constant M, vary N", "Subsubsection",
 CellChangeTimes->{{3.980932450309599*^9, 
  3.980932461624565*^9}},ExpressionUUID->"c2b13a16-4654-ab42-847e-\
5903b5e8cba5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"vals", "=", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Flatten", "@", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", "n", "}"}], ",", " ", 
          RowBox[{"Table", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"\[Psi]in", "=", 
              RowBox[{"createStateVector", "[", 
               RowBox[{"m", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"\[Psi]in", "=", 
              RowBox[{"setStateElement", "[", 
               RowBox[{"\[Psi]in", ",", 
                RowBox[{"Join", "[", 
                 RowBox[{
                  RowBox[{"{", "n", "}"}], ",", 
                  RowBox[{"ConstantArray", "[", 
                   RowBox[{"0", ",", 
                    RowBox[{"m", "-", "1"}]}], "]"}]}], "]"}], ",", "1"}], 
               "]"}]}], ";", 
             RowBox[{"(*", 
              TemplateBox[{
                RowBox[{
                  RowBox[{"N0", "..."}], "0"}]},
               "Ket"], "*)"}], "\[IndentingNewLine]", 
             RowBox[{"data", "=", 
              RowBox[{"ParallelTable", "[", 
               RowBox[{
                RowBox[{"1", "-", 
                 RowBox[{"Quiet", "[", 
                  RowBox[{"maxSepValRandomNetwork", "[", "\[Psi]in", "]"}], 
                  "]"}]}], ",", "howMany"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"Flatten", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Mean", "[", "data", "]"}], ",", 
                RowBox[{"Quantile", "[", 
                 RowBox[{"data", ",", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"1", "-", "quantile"}], ",", "quantile"}], 
                   "}"}]}], "]"}]}], "}"}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"m", ",", "2", ",", "6"}], "}"}]}], 
           "\[IndentingNewLine]", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "10"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], "//", "AbsoluteTiming"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<GME_over_N-Random-M=2_to_6-N=1_to_10.csv\>\"", ",", "vals"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9809324393036003`*^9, 3.980932439799919*^9}},
 CellLabel->"In[56]:=",ExpressionUUID->"c7915ad3-7818-874c-a09a-21f26907b70e"],

