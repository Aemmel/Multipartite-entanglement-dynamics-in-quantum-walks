Cell[CellGroupData[{

Cell["Entanglement Dynamics P=4 and P=8", "Subsubsection",
 CellChangeTimes->{{3.9809313368418255`*^9, 
  3.980931343939764*^9}},ExpressionUUID->"42f4a214-e517-6840-a6cc-\
6dadd2f06749"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"U", "=", 
   RowBox[{"UHadWalk", "[", "p", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxT", "=", "25"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"state", "=", 
   RowBox[{"N", "[", 
    RowBox[{"initState", "[", 
     RowBox[{"p", ",", "0", ",", "0"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"entDyn", "=", 
     RowBox[{"Join", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"1", "-", 
           RowBox[{"sepValOnePhoton", "[", "state", "]"}]}]}], "}"}], "}"}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"Table", "[", " ", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"state", "=", 
           RowBox[{"takeStep", "[", 
            RowBox[{"U", ",", "state"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"n", ",", 
            RowBox[{"1", "-", 
             RowBox[{"sepValOnePhoton", "[", "state", "]"}]}]}], "}"}]}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"n", ",", "1", ",", "maxT"}], "}"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "//", "AbsoluteTiming"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListPlot", "[", 
   RowBox[{"entDyn", ",", 
    RowBox[{"Joined", "->", "True"}]}], "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{
   RowBox[{"\"\<HW-full-N=1-P=\>\"", "<>", 
    RowBox[{"ToString", "@", "p"}], "<>", "\"\<-n=\>\"", "<>", 
    RowBox[{"ToString", "@", "maxT"}], "<>", "\"\<.csv\>\""}], ",", 
   "entDyn"}], "]"}]}], "Input",
 CellChangeTimes->{{3.980931358362816*^9, 3.9809313627252827`*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"b74b34c3-85fd-b24a-a776-d7c2ff9a6430"],

