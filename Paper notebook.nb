      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"k", "<", "1"}], "||", 
          RowBox[{"k", ">=", "m"}]}], ",", 
         RowBox[{"Print", "[", "\"\<k needs to fulfill: 1<=k<M!\>\"", "]"}]}],
         "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Sigma]", "[", 
           RowBox[{"{", 
            RowBox[{"i", ",", "j", ",", "k", ",", "l"}], "}"}], "]"}], " ", 
          "for", " ", "permutation"}], "==", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"4", ",", "1", ",", "3", ",", "2"}], "}"}], " ", "gives", " ", 
          RowBox[{"{", 
           RowBox[{"l", ",", "i", ",", "k", ",", "j"}], "}"}]}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[Sigma]", "[", "inds_", "]"}], ":=", 
        RowBox[{"Part", "[", 
         RowBox[{"inds", ",", 
          RowBox[{"InversePermutation", "@", "permutation"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"coeffM", "=", 
        RowBox[{"SparseArray", "[", 
         RowBox[{
          RowBox[{"{", "}"}], ",", 
