Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Showcasing", " ", "the", " ", "oscillatory", " ", "behavior"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"entDynR", "=", 
    RowBox[{
     RowBox[{"entDyn", "[", 
      RowBox[{"[", 
       RowBox[{";;", "250"}], "]"}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"maxs", "=", 
    RowBox[{
     RowBox[{"FindPeaks", "[", 
      RowBox[{"entDynR", ",", "0", ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "0"}]}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"mins", "=", 
    RowBox[{
     RowBox[{"FindPeaks", "[", 
      RowBox[{
       RowBox[{"-", "entDynR"}], ",", "0", ",", 
       RowBox[{"InterpolationOrder", "\[Rule]", "0"}]}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", "\"\<Differences:\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"maxs", "[", 
     RowBox[{"[", 
      RowBox[{"2", ";;"}], "]"}], "]"}], "-", 
    RowBox[{"maxs", "[", 
     RowBox[{"[", 
      RowBox[{";;", 
       RowBox[{"-", "2"}]}], "]"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mins", "[", 
     RowBox[{"[", 
      RowBox[{"2", ";;"}], "]"}], "]"}], "-", 
    RowBox[{"mins", "[", 
     RowBox[{"[", 
      RowBox[{";;", 
       RowBox[{"-", "2"}]}], "]"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9809314542340755`*^9, 3.980931472073551*^9}, {
  3.9809315969621487`*^9, 3.98093159736759*^9}},
