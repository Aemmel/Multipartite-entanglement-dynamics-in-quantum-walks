Cell[CellGroupData[{

Cell["Entanglement Dynamics P=500", "Subsubsection",
 CellChangeTimes->{{3.9809299777247677`*^9, 
  3.9809299837917976`*^9}},ExpressionUUID->"5adb8c92-e126-954b-ab86-\
c32632e61883"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", "=", "500"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"U", "=", 
   RowBox[{"UHadWalk", "[", "p", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxT", "=", "5000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"state", "=", 
   RowBox[{"N", "[", 
    RowBox[{"initState", "[", 
     RowBox[{"p", ",", "0", ",", "0"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"entDyn", "=", 
     RowBox[{"Join", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"1", "-", 
           RowBox[{"sepValOnePhoton", "[", "state", "]"}]}]}], "}"}], "}"}], ",",
        "\[IndentingNewLine]", 
       RowBox[{"Table", "[", " ", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"state", "=", 
           RowBox[{"takeStep", "[", 
            RowBox[{"U", ",", "state"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"n", ",", 
            RowBox[{"1", "-", 
             RowBox[{"sepValOnePhoton", "[", "state", "]"}]}]}], "}"}]}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"n", ",", "1", ",", "maxT"}], "}"}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "//", "AbsoluteTiming"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListPlot", "[", 
   RowBox[{"entDyn", ",", 
    RowBox[{"Joined", "->", "True"}]}], "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{
   RowBox[{"\"\<HW-full-N=1-P=\>\"", "<>", 
    RowBox[{"ToString", "@", "p"}], "<>", "\"\<-n=\>\"", "<>", 
    RowBox[{"ToString", "@", "maxT"}], "<>", "\"\<.csv\>\""}], ",", 
   "entDyn"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9809313864886265`*^9, 3.9809313960289097`*^9}},
 CellLabel->
  "In[119]:=",ExpressionUUID->"c484606d-f632-414e-80e1-44ef0bc7ef7d"],

