             RowBox[{"(", 
              RowBox[{"t", "+", "1"}], ")"}], "^", "k"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"n", "-", "t", "+", "1"}], ")"}], "^", 
             RowBox[{"(", 
              RowBox[{"m", "-", "k"}], ")"}]}]}], "}"}], ",", "0.0"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"i", "=", 
           RowBox[{"multiIndToInd", "[", 
            RowBox[{"multI", ",", 
             RowBox[{"t", "+", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"j", "=", 
           RowBox[{"multiIndToInd", "[", 
            RowBox[{"multJ", ",", 
             RowBox[{"n", "-", "t", "+", "1"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"coeffM", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", 
           RowBox[{"getStateElement", "[", 
            RowBox[{"\[Psi]", ",", 
             RowBox[{"\[Sigma]", "@", 
