Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"vals", "=", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Flatten", "@", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", "n", "}"}], ",", " ", 
          RowBox[{"Table", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"\[Psi]in", "=", 
              RowBox[{"createStateVector", "[", 
               RowBox[{"m", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"\[Psi]in", "=", 
              RowBox[{"setStateElement", "[", 
               RowBox[{"\[Psi]in", ",", 
                RowBox[{"Join", "[", 
                 RowBox[{
                  RowBox[{"{", "n", "}"}], ",", 
                  RowBox[{"ConstantArray", "[", 
                   RowBox[{"0", ",", 
                    RowBox[{"m", "-", "1"}]}], "]"}]}], "]"}], ",", "1"}], 
               "]"}]}], ";", 
             RowBox[{"(*", 
              TemplateBox[{
                RowBox[{
                  RowBox[{"N0", "..."}], "0"}]},
               "Ket"], "*)"}], "\[IndentingNewLine]", 
             RowBox[{"data", "=", 
              RowBox[{"ParallelTable", "[", 
               RowBox[{
                RowBox[{"1", "-", 
                 RowBox[{"Quiet", "[", 
                  RowBox[{"maxSepValRandomNetwork", "[", "\[Psi]in", "]"}], 
                  "]"}]}], ",", "howMany"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"Flatten", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Mean", "[", "data", "]"}], ",", 
                RowBox[{"Quantile", "[", 
                 RowBox[{"data", ",", "quantile"}], "]"}]}], "}"}], "]"}]}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"m", ",", "2", ",", "6"}], "}"}]}], 
           "\[IndentingNewLine]", "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "10"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], "//", "AbsoluteTiming"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<GME_over_N-Random-M=2_to_6-N=1_to_10.csv\>\"", ",", "vals"}], 
