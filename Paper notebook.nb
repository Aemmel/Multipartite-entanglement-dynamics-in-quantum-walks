Cell[CellGroupData[{

Cell["Entanglement dynamics for different partitions", "Subsubsection",
 CellChangeTimes->{{3.980932043734152*^9, 
  3.980932057524599*^9}},ExpressionUUID->"8fba6c9d-ffed-f943-a02f-\
373d58a4eba2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", "=", "64"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"U", "=", 
    RowBox[{"UHadWalk", "[", "p", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"state", "=", 
  RowBox[{
   RowBox[{"initState", "[", 
    RowBox[{"p", ",", "0", ",", "0"}], "]"}], "//", "N"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"partitionCoin", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Range", "[", 
      RowBox[{"1", ",", "p"}], "]"}], ",", 
     RowBox[{"Range", "[", 
      RowBox[{
       RowBox[{"p", "+", "1"}], ",", "p"}], "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"partitionPos", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"p", "+", "i"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "p"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"startEnt", "=", 
  RowBox[{"{", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{"0", ",", " ", "\[IndentingNewLine]", 
     RowBox[{"1", "-", 
      RowBox[{"sepValOnePhoton", "[", "state", "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"1", "-", 
      RowBox[{"sepValOnePhoton", "[", 
       RowBox[{"wStateDifferentPartition", "[", 
        RowBox[{"state", ",", "partitionCoin"}], "]"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"1", "-", 
      RowBox[{"sepValOnePhoton", "[", 
       RowBox[{"wStateDifferentPartition", "[", 
        RowBox[{"state", ",", "partitionPos"}], "]"}], "]"}]}], ",", 
     "\[IndentingNewLine]", "0"}], "\[IndentingNewLine]", "}"}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"vals", "=", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"state", "=", 
         RowBox[{"takeStep", "[", 
          RowBox[{"U", ",", "state"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{"n", ",", "\[IndentingNewLine]", 
          RowBox[{"1", "-", 
           RowBox[{"sepValOnePhoton", "[", "state", "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"1", "-", 
           RowBox[{"sepValOnePhoton", "[", 
            RowBox[{"wStateDifferentPartition", "[", 
             RowBox[{"state", ",", "partitionCoin"}], "]"}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"1", "-", 
           RowBox[{"sepValOnePhoton", "[", 
            RowBox[{"wStateDifferentPartition", "[", 
             RowBox[{"state", ",", "partitionPos"}], "]"}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\[Phi]1", "[", 
           RowBox[{"n", ",", "0", ",", "0"}], "]"}]}], "\[IndentingNewLine]", 
         "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "80"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], "//", "AbsoluteTiming"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"vals", "=", 
    RowBox[{"Join", "[", 
     RowBox[{"startEnt", ",", "vals"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListPlot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"vals", "\[Transpose]"}], "[", 
     RowBox[{"[", 
      RowBox[{"2", ";;"}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Joined", "\[Rule]", "True"}], ",", "\[IndentingNewLine]", 
    RowBox[{"GridLines", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "32", "}"}], ",", 
       RowBox[{"{", "}"}]}], "}"}]}]}], "\[IndentingNewLine]", "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<HW-diff_parts-N=1-P=64-n=100.csv\>\"", ",", 
   RowBox[{"N", "[", "vals", "]"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9809320674536266`*^9, 3.980932086452696*^9}, {
  3.980932144869341*^9, 3.9809321600317345`*^9}, {3.980932197485342*^9, 
