        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"SingularValueList", "[", 
        RowBox[{"coeffM", ",", "1"}], "]"}]}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sepValBipartition", "[", 
     RowBox[{"\[Psi]_", ",", "k_", ",", 
