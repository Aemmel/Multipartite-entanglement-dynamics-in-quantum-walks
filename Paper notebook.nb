Cell[CellGroupData[{

Cell["Varying the initial conditions from asymmetric to symmetric ", \
"Subsubsection",
 CellChangeTimes->{{3.980931876807089*^9, 
  3.9809319144978867`*^9}},ExpressionUUID->"ff2127c3-030d-8447-9829-\
090b1e4d8097"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"U", "=", 
    RowBox[{"UHadWalk", "[", "p", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]Vals", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", 
     RowBox[{"Pi", "/", "2"}], ",", 
     RowBox[{"0.002", "Pi"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nVals", "=", 
    RowBox[{"Range", "[", 
     RowBox[{"1", ",", "50"}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"vals", "=", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"state", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], 
           RowBox[{"initState", "[", 
            RowBox[{"p", ",", "0", ",", "0"}], "]"}]}], "+", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", 
             RowBox[{"Pi", "/", "2"}]}], "]"}], 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], " ", 
           RowBox[{"initState", "[", 
            RowBox[{"p", ",", "1", ",", "0"}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"1", "-", 
        RowBox[{"Join", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"sepValOnePhoton", "[", "state", "]"}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Table", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"state", "=", 
              RowBox[{"takeStep", "[", 
               RowBox[{"U", ",", "state"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"sepValOnePhoton", "[", "state", "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"n", ",", "nVals"}], "}"}]}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", "\[Theta]Vals"}], "}"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "//", "AbsoluteTiming"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PrependTo", "[", 
    RowBox[{"nVals", ",", "0"}], "]"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"allVals", "=", 
    RowBox[{"ArrayFlatten", "[", "\[IndentingNewLine]", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"-", "1"}], "}"}], "}"}], ",", 
         RowBox[{"{", "\[Theta]Vals", "}"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"{", "nVals", "}"}], "\[Transpose]"}], ",", 
         RowBox[{"vals", "\[Transpose]"}]}], "}"}]}], "\[IndentingNewLine]", 
      "}"}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListPlot", "[", 
   RowBox[{"vals", ",", 
    RowBox[{"Joined", "\[Rule]", "True"}]}], "]"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<HW-ICs-Sym-To-Asym-P=3-n=50.csv\>\"", ",", "allVals"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9809319281843567`*^9, 3.9809319975110245`*^9}, {
  3.9809970058625946`*^9, 3.9809970067135544`*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"801c9222-d26f-c04b-924c-6af58294e339"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.4826279`", ",", "Null"}], "}"}]], "Output",
