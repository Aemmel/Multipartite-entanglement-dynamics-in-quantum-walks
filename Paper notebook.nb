Cell[CellGroupData[{

Cell["Random one-photon networks (Sec. III.A)", "Subsection",
 CellChangeTimes->{{3.9809295670468884`*^9, 3.9809295995953217`*^9}, {
  3.98092964569368*^9, 3.980929652008665*^9}, {3.980929737181076*^9, 
  3.980929742808073*^9}},ExpressionUUID->"68ab9223-9510-be40-9b92-\
a5d4ea4e3410"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sepValEW", "[", "m_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"m", "-", "1"}], ")"}], "/", "m"}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"m", "-", "1"}], ")"}]}]}], 
  RowBox[{"(*", 
   RowBox[{
   "sep", " ", "val", " ", "equally", " ", "weighted", " ", "W", " ", 
    "state"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"equidistantLogPoints", "[", 
    RowBox[{"min_", ",", "max_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"10", "^", "i"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"Range", "[", 
        RowBox[{
         RowBox[{"Log10", "@", "min"}], ",", 
         RowBox[{"Log10", "@", "max"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Log10", "@", "max"}], "-", 
            RowBox[{"Log10", "@", "min"}]}], ")"}], "/", "n"}]}], "]"}]}], 
      "}"}]}], "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"howMany", "=", "5000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"quantile", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"0.5", "-", 
      RowBox[{"0.68", "/", "2"}]}], ",", 
     RowBox[{"0.5", "+", 
      RowBox[{"0.68", "/", "2"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"modeNumbersFine", "=", 
  RowBox[{"Floor", "@", 
   RowBox[{"N", "@", 
    RowBox[{"equidistantLogPoints", "[", 
     RowBox[{"2", ",", "200", ",", "50"}], "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"modeNumbersCoarse", "=", 
  RowBox[{"Floor", "@", 
   RowBox[{"N", "@", 
    RowBox[{"equidistantLogPoints", "[", 
     RowBox[{"200", ",", 
      RowBox[{"10", "^", "5"}], ",", "200"}], "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"modeNumbers", "=", 
  RowBox[{"DeleteDuplicates", "@", 
   RowBox[{"Join", "[", 
    RowBox[{"modeNumbersFine", ",", "modeNumbersCoarse"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Length", "@", "modeNumbers"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"randomW", "=", 
     RowBox[{"Table", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"data", "=", 
         RowBox[{"(*", "Parallel", "*)"}], 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"1", "-", 
            RowBox[{"sepValOnePhoton", "[", 
             RowBox[{"randomPointsOnSphere", "[", "m", "]"}], "]"}]}], ",", 
           "howMany"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"m", ",", " ", 
            RowBox[{"Mean", "[", "data", "]"}]}], "}"}], ",", 
          RowBox[{"Quantile", "[", 
           RowBox[{"data", ",", "quantile"}], "]"}]}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"m", ",", "modeNumbers"}], "}"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], "//", "AbsoluteTiming"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
  RowBox[{"\"\<Random-one-photon.csv\>\"", ",", "randomW"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9809323133174763`*^9, 3.980932314244301*^9}, {
   3.980932702730633*^9, 3.9809327028554783`*^9}, {3.9833328689035225`*^9, 
   3.9833328901354504`*^9}, {3.9833333400856724`*^9, 3.9833333725882587`*^9}, 
   3.9833339892318096`*^9, {3.9833464985262184`*^9, 3.9833465134133263`*^9}, {
   3.9834157929289627`*^9, 3.983415804099596*^9}, {3.9834158465657578`*^9, 
   3.983415866520544*^9}, {3.9834200968202515`*^9, 
   3.983420114935299*^9}},ExpressionUUID->"2e9df944-b288-db47-a290-\
31979dfe560c"]
}, Open  ]],

